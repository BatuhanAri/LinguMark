{
  "manifest_version": 3,
  "name": "LinguMark",
  "version": "1.1",
  "description": "Highlight and define words as you browse.",
  "icons": {
    "16": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "contextMenus",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-loader.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "LinguMark",
    "default_popup": "index.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js", "oxford.json"],
      "matches": ["<all_urls>"]
    }
  ]
}
